{
  "project": {
    "name": "Vermin Infestation",
    "engine": "Unity 2023 LTS (URP)",
    "platform": "Android APK"
  },
  "scenes": [
    {
      "name": "MainMenu",
      "path": "Assets/Scenes/MainMenu.unity",
      "keyGameObjects": [
        "Bootstrap (GameManager, PlayerProgressManager, SettingsManager, ScoreManager, CurrencyManager)",
        "Canvas_MainMenu",
        "Panel_MainMenu",
        "Panel_Settings",
        "MainMenuController"
      ]
    },
    {
      "name": "Game",
      "path": "Assets/Scenes/Game.unity",
      "keyGameObjects": [
        "RuntimeManagers (LevelGenerator, SpawnZoneManager, RatAIManager)",
        "PlayerRig",
        "Main Camera",
        "Weapon",
        "RatPool",
        "EffectsPool",
        "HUD Canvas"
      ]
    }
  ],
  "scripts": [
    { "name": "GameManager", "role": "Global state machine and scene/bootstrap orchestration" },
    { "name": "MainMenuController", "role": "Main menu UI binding and scene transition actions" },
    { "name": "HybridInputController", "role": "Combines gyro and touch input and forwards to weapon" },
    { "name": "SniperCameraController", "role": "Aiming camera transform control" },
    { "name": "ZoomController", "role": "Scope zoom tier control" },
    { "name": "WeaponController", "role": "Firing logic, raycast hit detection, recoil/effects integration" },
    { "name": "RatAIManager", "role": "Active rat lifecycle and pooling bridge" },
    { "name": "LevelGenerator", "role": "Seeded level/environment and spawn setup" },
    { "name": "SpawnZoneManager", "role": "Interval-driven rat spawn attempts across zones" },
    { "name": "ScoreManager", "role": "Score accumulation and miss events" },
    { "name": "CurrencyManager", "role": "Pellet balance and score conversion" },
    { "name": "PlayerProgressManager", "role": "Persistent player progression storage" },
    { "name": "SettingsManager", "role": "Persistent gameplay settings storage" },
    { "name": "HUDController", "role": "In-game score/timer/pellet UI updates" }
  ],
  "systems": {
    "input": [
      "GyroInputHandler",
      "TouchInputHandler",
      "InputSmoothingPipeline",
      "HybridInputController"
    ],
    "camera": [
      "SniperCameraController",
      "ZoomController",
      "BreathingSway",
      "ScopeOverlayController"
    ],
    "weapon": [
      "WeaponController",
      "RecoilSystem",
      "OpticsTierConfig"
    ],
    "ai": [
      "RatFSM",
      "RatAIManager",
      "MovementPathfinder",
      "ScatterBehavior"
    ],
    "pooling": [
      "RatObjectPool",
      "EffectsObjectPool"
    ],
    "level": [
      "EnvironmentTileLibrary",
      "LevelGenerator",
      "SpawnZoneManager",
      "LightingModeController",
      "LevelSeedGenerator"
    ],
    "scoring": [
      "ScoreManager",
      "ComboTracker",
      "CurrencyManager",
      "HitMarkerFeedback"
    ],
    "data": [
      "PlayerProgress",
      "PlayerProgressManager",
      "SettingsData",
      "SettingsManager"
    ],
    "ui": [
      "HUDController",
      "MainMenuController",
      "ScopeOverlayController"
    ]
  },
  "entryPoints": {
    "bootstrap": "GameManager",
    "flow": [
      "MainMenu scene loads with persistent bootstrap managers",
      "MainMenuController invokes GameManager.StartGame()",
      "Game scene loads and GameManager resolves runtime references",
      "GameManager drives timer/state and finalizes score -> pellets -> progress"
    ]
  },
  "build": {
    "target": "Android",
    "scriptingBackend": "IL2CPP",
    "requiredScenes": [
      "Assets/Scenes/MainMenu.unity",
      "Assets/Scenes/Game.unity"
    ],
    "notes": [
      "Use Development Build for debug APK validation",
      "Tune active rat cap and spawn interval for target hardware",
      "Keep pooling references assigned in inspector before device builds"
    ]
  }
}
